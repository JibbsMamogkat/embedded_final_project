# ==========================================
# C++ Compiler Outputs & Binaries
# ==========================================
*.exe
*.out
*.o
*.obj
*.a
*.lib
*.so
*.dll

# ==========================================
# Development Build Directories
# ==========================================
build/
bin/
obj/

# ==========================================
# IDE and System Specific Files
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log

# ==========================================
# Local Project Data & Mock Assets
# ==========================================
# Ignore large raw image files or video assets inside data
data/*
# Prevent ignoring the folder structure itself
!data/.gitkeep


# ==========================================
# Python & Virtual Environments
# ==========================================
venv/
env/
__pycache__/
*.pyc


# ==========================================
# ESP-IDF Specific
# ==========================================
sdkconfig.old
# Note: DO NOT ignore 'sdkconfig' itself, as both you and your partner 
# need the exact same compiler configuration state.